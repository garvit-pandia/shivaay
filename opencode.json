{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp", "--browser", "chromium", "--executable-path", "/home/garvit/.cache/ms-playwright/chromium-1226/chrome-linux64/chrome"],
      "enabled": true,
      "timeout": 30000
    }
  }
}
